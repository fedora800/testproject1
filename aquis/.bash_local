#.bash_local     #version-20-apr-2025

# --- PS1 prompt ---
if [[ ! "$USER" =~ ^aqx ]]
then
  # we have not done a sudo as any of the aqx users, meaning we can change the PS1
  export PS1="\[\033[01;32m\]\u@\h:\w\[\033[00m\]\n$ "
fi


# --- variables ---
DT_TODAY=$(date +"%F")

# --- aliases ---
alias jbgrep=f_jbgrep


# --- functions ---
function f_jbgrep()  {
  local pattern="$1"
  local files=(
    ~/todo-aqse_server_alias.sh
    ~/todo-aquis_alias.sh
    ~/todo-aquis_server_alias.sh
    ~/todo-general.alias.sh
  )
  grep -n --color=always "$pattern" "${files[@]}"
}


